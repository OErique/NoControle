# Banco PostgreSQL/Neon usado pelas rotas do app.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Alternativa aceita pelo app caso DATABASE_URL nao exista.
# POSTGRES_URL="postgresql://user:password@host/database?sslmode=require"

# Gere um segredo forte antes de publicar.
# Exemplo PowerShell:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="troque-por-um-segredo-forte"

# Opcional: modelo usado pelo Alfred via Vercel AI Gateway.
# Em producao, configure AI_GATEWAY_API_KEY ou habilite OIDC do AI Gateway na Vercel.
ALFRED_MODEL="openai/gpt-4o-mini"

# Opcional: voz do Alfred via ElevenLabs.
ELEVENLABS_API_KEY="sua-chave-da-elevenlabs"
ELEVENLABS_VOICE_ID="I2Laj5pnkMEVeBvM6pyf"
